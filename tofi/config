# --- Window Settings ---
width = 400
height = 600
anchor = center
outline-width = 0
border-width = 2
border-color = #7aa2f7      # Replace with your 'selected' color
background-color = #1a1b26  # Replace with your 'background' color
corner-radius = 0

# --- Text Settings ---
# Use a direct path to the font file for < 1ms startup speed
font = /usr/share/fonts/jetbrains-mono-fonts/JetBrainsMono-Regular.otf
font-size = 12
text-color = #c0caf5
prompt-text = "  "
prompt-padding = 10

# --- Selection Colors ---
selection-color = #7aa2f7
selection-background = #24283b
selection-background-padding = 5
selection-background-corner-radius = 2

# --- Behavior ---
num-results = 24
hide-cursor = true
drun-launch = true

