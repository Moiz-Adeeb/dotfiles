include ~/.config/i3/config.d/*.conf


# Setting Contants
set $mod Mod4
set $terminal alacritty
set $powermenu $HOME/.config/rofi/powermenu/powermenu.sh
set $menu $HOME/.config/rofi/launchers/launcher.sh
set $refresh_i3status killall -SIGUSR1 i3status


font pango:JetBrains Mono 12

for_window [class="float_small"] move scratchpad, scratchpad show, resize set 900 600, move position center
for_window [class="float_big"] move scratchpad, scratchpad show, resize set 1100 800, move position center
for_window [class="float_large"] move scratchpad, scratchpad show, resize set 1280 800, move position center

# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
bar {
    font pango: Font Awesome 6 Free 10, JetBrains Mono 12
    position top
    #mode hide
    hidden_state hide
    modifier $mod
    colors {
        background #000000
        statusline #FFFFFF
        separator  #666666

        statusline #C5C8C6

        # Recreating your Polybar "xworkspaces" look
        # class                 border     background text
        focused_workspace       #000000    #000000    #FFFFFF  
        active_workspace        #000000    #333333    #FFFFFF  
        inactive_workspace      #000000    #000000    #707880  
        urgent_workspace        #A54242    #A54242    #FFFFFF  

        #focused_workspace  #83CAFA #51A2DA #FFFFFF
        #active_workspace   #3C6EB4 #294172 #FFFFFF
        #inactive_workspace #8C8C8C #4C4C4C #888888
        #urgent_workspace   #EC69A0 #DB3279 #FFFFFF
        #binding_mode       #b691d3 #A07CBC #FFFFFF
    }
    status_command i3blocks -c ~/.config/i3blocks/config
}


gaps inner 0
gaps outer 0


default_border pixel 1
default_floating_border normal 0


smart_borders on
hide_edge_borders both
#smart_gaps on

popup_during_fullscreen smart

title_align center

for_window [class=".*"] border pixel 1


