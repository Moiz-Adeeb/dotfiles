backend = "glx";
vsync = true;
corner-radius = 12;

round-borders = 1;
round-borders-exclude = [
	"class_g = 'i3-frame'"
];

shadow = true;
shadow-radius = 12;
shadow-opacity = 0.4;

#fading = true;
#fade-in-step = 0.03;
#fade-out-step = 0.03;

opacity-rule = [
	"90:class_g = 'Alacritty'",
	"85:class_g = 'code'"
];

blur-background = true;
blur-method = "dual_kawase";
blur-strength = 5;

