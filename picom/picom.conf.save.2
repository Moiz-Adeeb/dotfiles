backend = "glx";
vsync = true;
corner-radius = 10;

round-borders = 1;
round-borders-exclude = [
	"class_g = 'i3-frame'"
];

shadow = true;
shadow-radius = 10;
shadow-opacity = 0.3;

fading = true;
fade-in-step = 0.04;
fade-out-step = 0.04;

opacity-rule = [
	"90:class_g = 'Alacritty'",
	"95:class_g = 'Terminator'",
	"09:class_g = 'Google Chrome'",
	"85:class_g = 'Code'"
];

blur-background = true;
blur-method = "dual_kawase";
blur-strength = 5;

