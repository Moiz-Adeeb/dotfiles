[Unit]
Description=Swaybg Wallpaper Daemon
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=/bin/sh -c 'exec uwsm app -- /usr/bin/swaybg -i "$(cat /home/moiz/.background_wallpaper)" -m fill'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=hyprland-session.target
