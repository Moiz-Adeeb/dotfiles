layout {
    gaps 8
    border {
        on
        width 2
        active-color "#33ccff"
        inactive-color "#bb9af7"
    }

    focus-ring {
        off
        width 1
        active-color "#33ccff"
        inactive-color "#bb9af7"
    }
}

window-rule {
    geometry-corner-radius 0
    clip-to-geometry true
}

animations {
    off
}

overview {
    zoom 0.5
    backdrop-color "#1a1b26"
}

cursor {
    xcursor-theme "Adwaita"
    xcursor-size 24
    hide-after-inactive-ms 5000
}

